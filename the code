import os


# file to store users
FILE = "users.json"


# load users from file
def load_users():
    if os.path.exists(FILE):
        with open(FILE, "r") as f:
            return json.load(f)
    return {}


# save users to file
def save_users(users):
    with open(FILE, "w") as f:
        json.dump(users, f)


# register a new user
def register(users):
    print("\n--- Register ---")
    while True:
        username = input("Choose a username: ")
        if username == "":
            print("Username cannot be empty.")
        elif any(char in "_.:!@#$%^&*()" for char in username):
            print("Username cannot contain special characters.")
        elif username in users:
            print("Username already exists. Please choose another.")
        else:
            break
    while True:
        password = input("Choose a password: ")
        if len(password) < 4:
            print("Password must be at least 4 characters.")
        else:
            break
    users[username] = password
    save_users(users)
    print(f"\nAccount created successfully! Welcome, {username}!")


# login an existing user
def login(users):
    print("\n--- Login ---")
    while True:
        username = input("Username: ")
        if username not in users:
            print("Username not found. Please try again.")
        else:
            break
    while True:
        password = input("Password: ")
        if users[username] != password:
            print("Incorrect password. Please try again.")
        else:
            break
    print(f"\nWelcome back, {username}!")


# delete an existing user
def delete(users):
    print("\n--- Delete Account ---")
    while True:
        username = input("Username: ")
        if username not in users:
            print("Username not found. Please try again.")
        else:
            break
    while True:
        password = input("Password: ")
        if users[username] != password:
            print("Incorrect password. Please try again.")
        else:
            break


    # confirm before deleting
    while True:
        confirm = input(f"Are you sure you want to delete '{username}'? (yes/no): ")
        if confirm.lower() == "yes":
            del users[username]
            save_users(users)
            print(f"\nAccount '{username}' has been deleted.")
            break
        elif confirm.lower() == "no":
            print("Deletion cancelled.")
            break
        else:
            print("Please type yes or no.")


